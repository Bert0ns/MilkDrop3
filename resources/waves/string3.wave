wave_0_per_frame1=t1 = (time + sin(time*2))*8;
wave_0_per_point1=n = sample*6.283;
wave_0_per_point2=
wave_0_per_point3=xp = 0.3;
wave_0_per_point4=yp = 0;
wave_0_per_point5=zp = 0;
wave_0_per_point6=
wave_0_per_point7=phs = sample;
wave_0_per_point8=
wave_0_per_point9=ang = t1 + phs;
wave_0_per_point10=sang = sin(ang) ; cang = cos(cang);
wave_0_per_point11=xq = xp*sang + yp*cang;
wave_0_per_point12=yq = xp*cang - yp*sang;
wave_0_per_point13=zq = zp;
wave_0_per_point14=xp = xq; yp = yq; zp = zq;
wave_0_per_point15=
wave_0_per_point16=ang = (t1+phs)*8.3;
wave_0_per_point17=sang = sin(ang) ; cang = cos(cang);
wave_0_per_point18=xq = xp*sang + zp*cang;
wave_0_per_point19=yq = yp;
wave_0_per_point20=zq = xp*cang - zp*sang;
